# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# These are read by the main process at startup (see src/main/secrets/api-keys.ts
# and src/main/calendar/config.ts). All are optional — the app also accepts keys
# entered in Settings — but a .env is the quickest path for local dev.

# Transcription / enhancement (optional; can also be set in Settings → API keys)
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=

# ── Google Calendar (ROADMAP_06) ────────────────────────────────────────────
# A "Desktop app" OAuth client. The client ID is bundled in calendar/config.ts;
# the client SECRET is required by Google's token exchange and is read here (never
# committed). Without the secret, Settings → Calendar → Connect throws "not
# configured". See docs/CALENDAR_SETUP.md for the one-time (~5 min) setup.
#
# CLIENT_ID is optional here (overrides the bundled one); CLIENT_SECRET is required.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Microsoft / Outlook Calendar (ROADMAP_06) ───────────────────────────────
# An Entra "Mobile & desktop" (public) OAuth client. Unlike Google, it needs NO
# client secret (PKCE). Set the Application (client) ID from the Azure Portal app
# registration. TENANT defaults to "common" (work/school + personal accounts);
# use "organizations" for work-only or a tenant GUID for a single directory.
# See docs/CALENDAR_SETUP.md.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_TENANT=common
