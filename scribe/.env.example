# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# These are read by the main process at startup (see src/main/secrets/api-keys.ts
# and src/main/calendar/config.ts). All are optional — the app also accepts keys
# entered in Settings — but a .env is the quickest path for local dev.

# Transcription / enhancement (optional; can also be set in Settings → API keys)
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=

# ── Google Calendar (ROADMAP_06) ────────────────────────────────────────────
# A PUBLIC OAuth client ID for a "Desktop app" client (PKCE — there is NO secret).
# Without it, Settings → Calendar → Connect throws "not configured".
#
# One-time setup (~5 min), see docs/CALENDAR_SETUP.md for the click-by-click:
#   1. console.cloud.google.com → create/select a project.
#   2. APIs & Services → Enable APIs → enable "Google Calendar API".
#   3. OAuth consent screen → External → add scope
#      .../auth/calendar.events.readonly → add yourself as a Test user.
#   4. Credentials → Create credentials → OAuth client ID → type "Desktop app".
#   5. Paste the generated client ID below.
GOOGLE_OAUTH_CLIENT_ID=
