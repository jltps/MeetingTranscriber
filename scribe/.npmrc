; Native modules (better-sqlite3) are built for Electron's ABI, not Node's,
; because this app only loads them inside the Electron main process. Targeting
; Electron lets `pnpm install` download a prebuilt binary instead of compiling
; from source, so no Visual Studio C++ toolchain is required. Keep `target` in
; sync with the pinned electron version in package.json.
runtime=electron
target=33.4.11
disturl=https://electronjs.org/headers
build-from-source=false
auto-install-peers=true
strict-peer-dependencies=false
